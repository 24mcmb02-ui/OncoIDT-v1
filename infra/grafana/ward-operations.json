{
  "uid": "ward-ops",
  "title": "Ward Operations",
  "schemaVersion": 38,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "tags": ["oncoidt", "ward"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Patients Total",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(onco_active_patients_total)",
          "legendFormat": "Active Patients",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "High-Risk Patient Count",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(onco_active_patients_total{ward_id=~\".+\"})",
          "legendFormat": "High-Risk Patients",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 10 }
          ]
        }
      }
    },
    {
      "id": 3,
      "type": "barchart",
      "title": "Alert Volume by Priority",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (priority) (increase(onco_alert_generated_total[1h]))",
          "legendFormat": "{{priority}}",
          "refId": "A"
        }
      ],
      "options": {
        "xField": "priority",
        "orientation": "auto",
        "groupWidth": 0.7,
        "barWidth": 0.97
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Score Staleness Total",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(onco_score_staleness_total)",
          "legendFormat": "Stale Scores",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      }
    }
  ]
}
